# PostgreSQL (Docker Compose only)
POSTGRES_PASSWORD=

# JWT — generate a random 64-char hex string
JWT_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# CORS — comma-separated origins allowed by the backend
# ALLOWED_ORIGINS=https://car-rental-client.onrender.com

# SMTP (optional — email invoices)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Client build-time vars (set in Render dashboard for static site)
# VITE_API_URL=https://car-rental-server.onrender.com/api
# VITE_GOOGLE_CLIENT_ID=
